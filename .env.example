# OpenAI is used for the agentic workflow's caption generation, scoring,
# adversarial brand review, and the omni-moderation API. The app degrades
# gracefully (baked-in captions + heuristic scoring + blocklist-only safety)
# when this is missing, so it's optional but strongly recommended.
# Required in production — powers moderation + brand review on every customize/save.
OPENAI_API_KEY=

# Optional: block saves when moderation API fails even in development.
# REQUIRE_MODERATION_API=true

# Model used by app/lib/llm.js. Defaults to gpt-4.1-mini if unset.
OPENAI_MODEL=gpt-4.1-mini

# Optional: full canonical site URL. Used for absolute Open Graph image
# URLs on /meme/[id] share pages (so social previews work). Falls back
# to VERCEL_URL or http://localhost:3001.
# NEXT_PUBLIC_SITE_URL=https://www.teacher-memes.com

# GA4 — see docs/GA4-SETUP.md. Required in production for hub metrics.
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional — defaults to GTM-WCMKBMHT
# NEXT_PUBLIC_GTM_ID=GTM-WCMKBMHT

# Vercel Blob — required in production for persistent customize/generate saves.
# Create a Blob store in Vercel (Project → Storage → Blob); the token is
# injected automatically. Without it, customize still works but share links
# won't persist after the session.
# BLOB_READ_WRITE_TOKEN=
